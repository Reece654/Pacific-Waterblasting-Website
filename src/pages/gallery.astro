---
/*
  gallery.astro
  shows before and after photos of completed jobs.
  images are stored in public/images and served from the /images/ path.
  to add a new job, add an entry to the jobs array with the correct filenames.
*/

import Layout from '../layouts/Layout.astro';

// job entries, each one needs a matching before and after image in public/images
const jobs = [
  {
    id: 1,
    title: "Concrete Driveway",
    location: "Waipa",
    type: "Driveway",
    before: "/images/Driveway Before 2.jpg",
    after: "/images/Driveway After 2.jpg",
  },
  {
    id: 2,
    title: "Concrete Pathway",
    location: "Waipa",
    type: "Pathway",
    before: "/images/Pathway Before.jpg",
    after: "/images/Pathway After.jpg",
  },
  {
    id: 3,
    title: "Timber Deck",
    location: "Waipa",
    type: "Deck",
    before: "/images/Deck Before 2.jpg",
    after: "/images/Deck After 2.jpg",
  },
  {
    id: 4,
    title: "Timber Deck",
    location: "Waipa",
    type: "Deck",
    before: "/images/Deck Before 1.jpg",
    after: "/images/Deck After 1.jpg",
  },
];
---

<Layout title="Gallery | Pacific Waterblasting" description="Before and after photos of waterblasting jobs in Te Awamutu. Driveways, pathways, and decks.">
  <!-- page header -->
  <section class="gallery-hero">
    <div class="hero-inner">
      <p class="eyebrow">Our work</p>
      <h1>Before &amp; After</h1>
      <p class="hero-sub">Real results from real jobs in Waipa.</p>
    </div>
  </section>

  <!-- one job per row, before and after side by side -->
  <section class="gallery-section">
    <div class="gallery-inner">
      {jobs.map((job) => (
        <div class="job-card">

          <!-- job label sits above the photos -->
          <div class="job-info">
            <span class="job-type">{job.type}</span>
            <h3>{job.title}</h3>
            <p>{job.location}</p>
          </div>

          <!-- before and after photos, portrait ratio to match phone photos -->
          <div class="job-images">
            <div class="job-photo">
              <span class="photo-label">Before</span>
              <img src={job.before} alt={`${job.title} before cleaning`} loading="lazy" />
            </div>
            <div class="job-photo">
              <span class="photo-label after">After</span>
              <img src={job.after} alt={`${job.title} after cleaning`} loading="lazy" />
            </div>
          </div>

        </div>
      ))}
    </div>
  </section>

  <!-- nudge anyone browsing the gallery to get in touch -->
  <section class="cta-band">
    <div class="cta-inner">
      <h2>Like what you see?</h2>
      <p>Get in touch for a free quote on your property.</p>
      <a href="/contact" class="btn-white">Get a Quote</a>
    </div>
  </section>

</Layout>

<style>
  /* page header */
  .gallery-hero {
    background: var(--bg-light);
    padding: 4rem 1.5rem 2.5rem;
    border-bottom: 1px solid #e0f2fe;
  }
  .hero-inner { max-width: 700px; margin: 0 auto; }
  .eyebrow {
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--blue);
    margin-bottom: 0.75rem;
  }
  .gallery-hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 900;
    margin-bottom: 0.75rem;
    color: var(--dark);
  }
  .hero-sub { color: #475569; font-size: 1.05rem; line-height: 1.6; }

  /* single column, each job gets its own full width row */
  .gallery-section { padding: 4rem 1.5rem 5rem; background: var(--white); }
  .gallery-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  /* each job card is full width */
  .job-card {
    border: 1px solid #e0f2fe;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(27,108,168,0.07);
  }

  /* job label row at the top of each card */
.job-info {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #e0f2fe;
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    gap: 0.35rem;
    background: var(--bg-light);
  }
  .job-type {
    display: inline-block;
    background: #dbeafe;
    color: var(--blue);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .job-info h3 { font-size: 1rem; font-weight: 700; color: var(--dark); margin: 0; }
  .job-info p { font-size: 0.85rem; color: #64748b; margin: 0; }

  /* before and after sit side by side, each half the card width */
  .job-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  /* portrait aspect ratio matches phone photos, minimal cropping */
  .job-photo {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
  }
.job-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    display: block;
  }

  .photo-label {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--dark);
    color: var(--white);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 1;
  }
  .photo-label.after { background: var(--blue); }

  /* cta band */
  .cta-band { background: var(--blue); padding: 4rem 1.5rem; text-align: center; }
  .cta-inner { max-width: 600px; margin: 0 auto; }
  .cta-band h2 { color: var(--white); font-size: 1.8rem; font-weight: 900; margin-bottom: 0.75rem; }
  .cta-band p { color: #bfdbfe; margin-bottom: 1.5rem; font-size: 1.05rem; }
  .btn-white {
    display: inline-block;
    background: var(--white);
    color: var(--blue);
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 700;
  }
  .btn-white:hover { background: var(--bg-light); }

  /* stacks images vertically on mobile */
  @media (max-width: 600px) {
    .job-images { grid-template-columns: 1fr; }
  }
</style>