---
/*
  contact.astro
  the contact and quote request page.
  form uses Netlify forms so submissions come through without needing a backend.
*/

import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Pacific Waterblasting" description="Get a free waterblasting quote in Te Awamutu. Contact Pacific Waterblasting for driveways and decks.">

  <!-- page header -->
  <section class="contact-hero">
    <div class="contact-inner">
      <h1>Get a Free Quote</h1>
      <p>Fill in the form below and we'll get back to you promptly. Or just give us a call.</p>
    </div>
  </section>

  <section class="contact-body">
    <div class="contact-grid">

      <!-- quote request form, data-netlify tells Netlify to handle submissions -->
      <div class="form-wrap">
        <h2>Request a Quote</h2>
        <form name="contact" method="POST" data-netlify="true">
          <input type="hidden" name="form-name" value="contact" />

          <div class="field">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" placeholder="John Smith" required />
          </div>

          <div class="field">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" placeholder="021 123 4567" required />
          </div>

          <div class="field">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="john@email.com" />
          </div>

          <!-- dropdown lets us know what service they're after before we call back -->
          <div class="field">
            <label for="service">Service Needed</label>
            <select id="service" name="service">
              <option value="">Select a service...</option>
              <option value="driveway">Driveway Cleaning</option>
              <option value="deck">Deck Cleaning</option>
              <option value="other">Other / Not Sure</option>
            </select>
          </div>

          <div class="field">
            <label for="address">Property Address</label>
            <input type="text" id="address" name="address" placeholder="123 Example St, Te Awamutu" />
          </div>

          <div class="field">
            <label for="message">Anything else we should know?</label>
            <textarea id="message" name="message" rows="4" placeholder="e.g. size of driveway, condition, access notes..."></textarea>
          </div>

          <button type="submit">Send Request</button>
        </form>
      </div>

      <!-- contact details shown alongside the form -->
      <div class="details-wrap">
        <h2>Contact Details</h2>

        <div class="detail-item">
          <span class="detail-label">Phone</span>
          <a href="tel:+642040699793" class="detail-value">020 4069 9793</a>
        </div>

        <div class="detail-item">
          <span class="detail-label">Location</span>
          <span class="detail-value">Te Awamutu & surrounds</span>
        </div>

        <div class="detail-item">
          <span class="detail-label">Availability</span>
          <span class="detail-value">Weekends</span>
        </div>

        <div class="detail-item">
          <span class="detail-label">Response time</span>
          <span class="detail-value">Usually within a few hours</span>
        </div>

        <!-- service area box, helps customers know if we cover their location -->
        <div class="service-area">
          <h3>Service Area</h3>
          <p>Based in Te Awamutu. We cover Te Awamutu, Cambridge, Otorohanga, and surrounding areas.</p>
        </div>

        <div class="fb-link">
          <p>You can also message us on Facebook:</p>
          <a href="https://facebook.com/pacificwaterblasting" target="_blank" rel="noopener">Pacific Waterblasting on Facebook →</a>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  /* page header */
  .contact-hero {
    background: var(--bg-light);
    padding: 4rem 1.5rem 2rem;
    border-bottom: 1px solid #e0f2fe;
  }
  .contact-inner { max-width: 700px; margin: 0 auto; }
  .contact-hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 900;
    margin-bottom: 0.75rem;
    color: var(--dark);
  }
  .contact-hero p { color: #475569; font-size: 1.05rem; line-height: 1.6; }

  /* two column layout, form on the left, details on the right */
  .contact-body { padding: 3rem 1.5rem 5rem; }
  .contact-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  /* form styles */
  .form-wrap h2, .details-wrap h2 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--dark);
  }
  .field { display: flex; flex-direction: column; margin-bottom: 1.25rem; }
  label { font-size: 0.9rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--dark); }
  input, select, textarea {
    border: 1.5px solid #cbd5e1;
    border-radius: 6px;
    padding: 0.65rem 0.9rem;
    font-size: 0.95rem;
    font-family: var(--font);
    color: var(--dark);
    transition: border-color 0.2s;
  }
  input:focus, select:focus, textarea:focus { outline: none; border-color: var(--blue); }
  textarea { resize: vertical; }
  button[type="submit"] {
    background: var(--blue);
    color: var(--white);
    border: none;
    padding: 0.85rem 2rem;
    border-radius: 6px;
    font-size: 1rem;
    font-weight: 700;
    font-family: var(--font);
    cursor: pointer;
    width: 100%;
    margin-top: 0.5rem;
  }
  button[type="submit"]:hover { background: #38BDF8; }

  /* contact details section */
  .detail-item {
    display: flex;
    flex-direction: column;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #e2e8f0;
  }
  .detail-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--blue);
    margin-bottom: 0.25rem;
  }
  .detail-value { font-size: 1rem; color: var(--dark); text-decoration: none; font-weight: 600; }
  .detail-value:hover { color: var(--blue); }

  /* service area callout box -->
  .service-area {
    background: var(--bg-light);
    border-radius: 8px;
    padding: 1.25rem;
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .service-area h3 { font-size: 0.9rem; font-weight: 700; color: var(--blue); margin-bottom: 0.4rem; }
  .service-area p { font-size: 0.9rem; color: #475569; line-height: 1.6; }

  .fb-link p { font-size: 0.9rem; color: #475569; margin-bottom: 0.25rem; }
  .fb-link a { color: var(--blue); font-weight: 600; text-decoration: none; }
  .fb-link a:hover { text-decoration: underline; }

  /* stacks to single column on mobile */
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>